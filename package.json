{
  "name": "vuact-workspace",
  "version": "0.1.0-alpha.4",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "clean": "pnpm -r clean",
    "format": "prettier --write .",
    "lint": "eslint --fix",
    "lint-staged": "lint-staged",
    "playground": "pnpm --filter playground playground:dev",
    "examples": "pnpm --filter examples examples:dev",
    "release": "node scripts/release.js",
    "test": "NODE_ENV=production vitest --run",
    "test:coverage": "vitest --coverage"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,jsx,tsx,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "vuact": "workspace:^",
    "vuact-dom": "workspace:^",
    "@eslint/compat": "^1.2.0",
    "@eslint/js": "^9.12.0",
    "@jest/expect-utils": "^29.7.0",
    "@tsconfig/node18": "^18.2.2",
    "@types/jsdom": "^21.1.6",
    "@types/lodash-es": "^4.17.0",
    "@types/node": "^22.13.10",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitejs/plugin-vue-jsx": "^4.0.0",
    "@vitest/coverage-istanbul": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "@vitest/ui": "^3.0.0",
    "@vue/eslint-config-prettier": "^10.0.0",
    "@vue/eslint-config-typescript": "^14.0.0",
    "@vue/test-utils": "^2.4.3",
    "@vue/tsconfig": "^0.7.0",
    "chalk": "^5.3.0",
    "enquirer": "^2.4.1",
    "eslint": "^9.0.0",
    "eslint-plugin-import": "^2.30.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "eslint-plugin-vue": "^10.0.0",
    "expect": "^29.7.0",
    "immutable": "^4.3.7",
    "jest-diff": "^29.7.0",
    "jest-matcher-utils": "^29.7.0",
    "jsdom": "^26.0.0",
    "less": "^4.2.0",
    "lint-staged": "^16.0.0",
    "lodash-es": "^4.17.0",
    "picocolors": "^1.1.1",
    "prettier": "^3.1.0",
    "pretty-format": "^29.7.0",
    "prop-types": "^15.8.1",
    "random-seed": "^0.3.0",
    "react": "*",
    "react-cache": "2.0.0-alpha.1",
    "react-dom": "*",
    "react-lifecycles-compat": "^3.0.4",
    "replace-in-file": "^8.3.0",
    "scheduler": "0.23.2",
    "semver": "^7.7.1",
    "simple-git-hooks": "^2.11.1",
    "typescript": "^5.3.3",
    "use-sync-external-store": "^1.2.2",
    "vite": "^6.0.0",
    "vite-plugin-commonjs": "^0.10.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^3.0.0",
    "vue": "*"
  },
  "packageManager": "pnpm@10.10.0",
  "pnpm": {
    "overrides": {
      "@types/react": "^18.0.0",
      "@types/react-dom": "^18.0.0",
      "@vue/reactivity": "3.5.28",
      "@vue/runtime-dom": "npm:@vuact/runtime-dom@3.5.28-vuact.2",
      "@vue/server-renderer": "3.5.28",
      "react": "^18.0.0",
      "react-dom": "^18.0.0",
      "vue": "3.5.28"
    }
  }
}
